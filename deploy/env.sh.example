# Secrets for Terraform, supplied as environment variables rather than committed
# config. Copy to env.sh (gitignored) and fill in real values, then:
#
#   source env.sh
#   terraform plan
#
# Terraform automatically maps TF_VAR_<name> to the variable <name>.

# DigitalOcean API token (var.do_token).
export TF_VAR_do_token="dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Secret API key the chat UI uses to call the managed agent (var.agent_api_key).
# Mint one out-of-band: DO console > GenAI Platform > Agents > the agent >
# API Keys > Create Key (or POST /v2/gen-ai/agents/<uuid>/api_keys). The provider
# has no resource to create agent API keys, so it is operator-supplied here.
export TF_VAR_agent_api_key="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Spaces (S3-compatible) credentials for the knowledge-base documents bucket
# (var.spaces_access_id / var.spaces_secret_key).
export TF_VAR_spaces_access_id="DOxxxxxxxxxxxxxxxxxxxx"
export TF_VAR_spaces_secret_key="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# The s3 state backend authenticates via these standard AWS env vars (same
# DigitalOcean Spaces key as above).
export AWS_ACCESS_KEY_ID="$TF_VAR_spaces_access_id"
export AWS_SECRET_ACCESS_KEY="$TF_VAR_spaces_secret_key"
